{
  "name": "@edulution-io/ui-kit",
  "version": "2.0.87",
  "description": "Edulution UI component library built with React, TypeScript, Tailwind CSS",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/edulution-io/ui-kit.git"
  },
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./styles/theme.css": "./styles/theme.css",
    "./styles/fonts": "./styles/fonts.js",
    "./tailwind.config": "./tailwind.config.js",
    "./package.json": "./package.json"
  },
  "files": [
    "*.js",
    "*.d.ts",
    "*.map",
    "*.css",
    "components",
    "constants",
    "styles",
    "utils",
    "tailwind.config.js",
    "README.md",
    "LICENSE",
    "LICENSE_EXCEPTIONS.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && cp package.json dist/package.json && cp README.md dist/README.md && cp LICENSE dist/LICENSE && cp LICENSE_EXCEPTIONS.md dist/LICENSE_EXCEPTIONS.md"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-hook-form": "^7.51.1",
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "react-hook-form": {
      "optional": false
    },
    "tailwindcss": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.2",
    "vite": "npm:rolldown-vite@7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwindcss",
    "shadcn",
    "edulution"
  ],
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@fontsource/lato": "^5.2.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-table": "^8.11.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^0.2.0",
    "framer-motion": "^11.0.3",
    "input-otp": "^1.2.4",
    "qrcode.react": "^3.1.0",
    "react-day-picker": "^8.10.1",
    "react-dropzone": "^14.2.3",
    "tailwind-merge": "^2.2.1"
  }
}
